{
  "version": "2026-06-08",
  "cases": [
    {
      "id": "run_named_prebuilt_export",
      "prompt": "Run this named prebuilt on one row and export the result.",
      "expectedPieces": [
        "Getting Started With Deepline Plays",
        "Run, Export, Inspect, Repair"
      ],
      "requiredCommands": [
        "deepline plays describe prebuilt/<name> --json",
        "deepline plays run prebuilt/<name> --input '{...}' --watch",
        "deepline runs export <run-id> --dataset result.rows --out rows.csv"
      ],
      "skillNeedles": [
        "Describe before spend",
        "Direct-run only when exact"
      ],
      "referenceNeedles": [
        "Pilot before scale",
        "Good export output"
      ]
    },
    {
      "id": "csv_wrapper_projection",
      "prompt": "Upload a CSV, map headers, add status and miss_reason, then export clean rows.",
      "expectedPieces": [
        "Getting Started With Deepline Plays",
        "Run, Export, Inspect, Repair"
      ],
      "requiredCommands": [
        "deepline plays bootstrap <family> --from <source> --using play:prebuilt/<candidate> --limit 5 --out workflow.play.ts",
        "deepline plays check workflow.play.ts",
        "deepline runs export <run-id> --dataset result.rows --out rows.csv"
      ],
      "skillNeedles": [
        "Bootstrap/wrap when",
        "Project to flat user-facing columns"
      ],
      "referenceNeedles": [
        "flat user-facing headers",
        "status`, `miss_reason"
      ]
    },
    {
